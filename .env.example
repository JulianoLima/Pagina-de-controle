# ==========================================
# Banco de dados (Prisma + SQLite por padrão)
# ==========================================
DATABASE_URL="file:./dev.db"

# ==========================================
# NextAuth (autenticação)
# Gere um segredo forte: openssl rand -base64 32
# ==========================================
NEXTAUTH_SECRET="troque-este-valor-por-um-segredo-forte"
NEXTAUTH_URL="http://localhost:3000"

# ==========================================
# Microsoft Graph / Azure AD
# Registre um app em: https://portal.azure.com
#   1. Entra ID > App registrations > New registration
#   2. Certificates & secrets > New client secret
#   3. API permissions > Microsoft Graph > Application > Files.Read.All + Sites.Read.All
#   4. Conceder consentimento do admin
# ==========================================
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""

# ==========================================
# Planilha alvo do SharePoint/OneDrive
# SHAREPOINT_USER_UPN: email da conta que é dona do arquivo no OneDrive
# SHAREPOINT_FILE_PATH: caminho dentro do OneDrive/Drive
# SHAREPOINT_WORKSHEET: nome da aba que vira fonte do dashboard
# ==========================================
SHAREPOINT_USER_UPN="rdsiqueira@pr.sebrae.com.br"
SHAREPOINT_FILE_PATH="/Documents/Planilha.xlsx"
SHAREPOINT_WORKSHEET="Geral Projetos"

# Intervalo de polling em segundos (default 60)
SYNC_INTERVAL_SECONDS="60"

# Modo mock: "true" usa dados de exemplo sem consultar o Graph
USE_MOCK_DATA="true"

# ==========================================
# Admin inicial criado pelo seed
# ==========================================
SEED_ADMIN_EMAIL="juliano.lima@sebrae.com.br"
SEED_ADMIN_NAME="Juliano Lima"
SEED_ADMIN_PASSWORD="ChangeMe@123"
